{
  "manifest_version": "0.4",
  "name": "@nimblebraininc/files",
  "version": "0.1.0",
  "description": "Workspace file store — browse, search, read, write, and tag files",
  "author": {
    "name": "NimbleBrain Inc",
    "email": "hello@nimblebrain.ai"
  },
  "server": {
    "type": "node",
    "entry_point": "src/server.ts",
    "mcp_config": {
      "command": "bun",
      "args": ["${__dirname}/src/server.ts"]
    }
  },
  "_meta": {
    "ai.nimblebrain/host": {
      "host_version": "1.0",
      "name": "Files",
      "icon": "folder",
      "placements": [
        {
          "slot": "sidebar",
          "resourceUri": "ui://files/browser",
          "route": "@nimblebraininc/files",
          "label": "Files",
          "icon": "folder",
          "priority": 3
        }
      ]
    }
  }
}
