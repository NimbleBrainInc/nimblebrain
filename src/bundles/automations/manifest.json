{
  "manifest_version": "0.4",
  "name": "@nimblebraininc/automations",
  "version": "0.1.0",
  "description": "Scheduled automations: create, manage, and monitor recurring agent runs",
  "author": {
    "name": "NimbleBrain Inc",
    "email": "hello@nimblebrain.ai"
  },
  "server": {
    "type": "node",
    "entry_point": "src/server.ts",
    "mcp_config": {
      "command": "bun",
      "args": ["${__dirname}/src/server.ts"]
    }
  },
  "_meta": {
    "ai.nimblebrain/host": {
      "host_version": "1.0",
      "name": "Automations",
      "icon": "clock",
      "primaryView": {
        "resourceUri": "ui://automations/panel"
      },
      "placements": [
        {
          "slot": "sidebar",
          "resourceUri": "ui://automations/panel",
          "route": "@nimblebraininc/automations",
          "label": "Automations",
          "icon": "clock",
          "priority": 3
        }
      ]
    }
  }
}
