:8080 {
    handle /v1/* {
        reverse_proxy {$PLATFORM_URL}
    }
    handle /mcp* {
        reverse_proxy {$PLATFORM_URL}
    }
    handle /.well-known/* {
        reverse_proxy {$PLATFORM_URL}
    }
    handle {
        root * /srv
        try_files {path} /index.html
        file_server
    }
}
