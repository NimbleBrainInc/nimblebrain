{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "../.tmp-codegen",
    "rootDir": "../src/tools/platform/schemas",
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true
  },
  "include": ["../src/tools/platform/schemas/**/*.ts"]
}
